#!/usr/bin/env bash
set -euo pipefail

# release — Repo-agnostic versioning and release tool
#
# Walks up from $PWD to find the nearest .git directory, then operates on
# a VERSION file and CHANGELOG.md at that repo root. No per-unit mappings,
# no frontend sync — just simple repo-level semver with conventional
# commit analysis.
#
# Usage:
#   release init [<version>]  Set up VERSION + CHANGELOG.md
#   release <bump>            Bump and release (major|minor|patch|<semver>)
#   release --suggest         Print analysis and exit
#   release --from-commits    Auto-propose bump from commits
#   release --dry-run         Preview without side effects
#   release --push            Push commit and tag to origin
#   release --yes             Skip confirmations (CI-friendly)
#
# Features:
#   - Auto-detects repo root (walks up to .git, stops at $HOME)
#   - Prompts to initialize if VERSION is missing
#   - Conventional commit analysis for automatic bump proposals
#   - CHANGELOG.md: simple [Unreleased] rotation or generated from commits
#   - Commit: release: v<X.Y.Z>, Tag: v<X.Y.Z>

# ── Helpers ───────────────────────────────────────────────────────────

log()  { echo -e "\033[1;34m==>\033[0m $*"; }
ok()   { echo -e "\033[1;32m  ✓\033[0m $*"; }
warn() { echo -e "\033[1;33m  ⚠\033[0m $*"; }
fail() { echo -e "\033[1;31m  ✗\033[0m $*" >&2; exit 1; }

# ── Repo root detection ───────────────────────────────────────────────

find_repo_root() {
    local dir
    dir="$(cd "$1" 2>/dev/null && pwd)" || return 1
    while true; do
        if [[ -d "$dir/.git" ]]; then
            echo "$dir"
            return 0
        fi
        [[ "$dir" == "$HOME" || "$dir" == "/" ]] && break
        dir="$(dirname "$dir")"
    done
    return 1
}

# ── Init ──────────────────────────────────────────────────────────────

cmd_init() {
    local version="${1:-0.1.0}"
    if [[ -f "$REPO_ROOT/VERSION" ]]; then
        warn "VERSION already exists ($(tr -d '[:space:]' < "$REPO_ROOT/VERSION"))."
        return 0
    fi
    echo "$version" > "$REPO_ROOT/VERSION"
    ok "Created VERSION ($version)"
    if [[ ! -f "$REPO_ROOT/CHANGELOG.md" ]]; then
        cat > "$REPO_ROOT/CHANGELOG.md" <<'EOF'
# Changelog

## [Unreleased]
EOF
        ok "Created CHANGELOG.md"
    fi
    echo ""
    log "Release tracking initialized for $(basename "$REPO_ROOT")"
    echo "  Next: run 'release <major|minor|patch>' to cut a release"
}

# ── Semver bump ───────────────────────────────────────────────────────

bump_version() {
    local major minor patch
    IFS='.' read -r major minor patch <<< "$1"
    case "$2" in
        major) echo "$((major + 1)).0.0" ;;
        minor) echo "${major}.$((minor + 1)).0" ;;
        patch) echo "${major}.${minor}.$((patch + 1))" ;;
        *)
            [[ "$2" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] && echo "$2" || echo ""
            ;;
    esac
}

# ── Commit collection & bump proposal ─────────────────────────────────
# Sets globals: COMMITS_FILE, PROPOSED_BUMP

collect_commits() {
    COMMITS_FILE="$(mktemp)"
    trap 'rm -f "$COMMITS_FILE"' EXIT

    local last_tag
    last_tag=$(git -C "$REPO_ROOT" tag -l 'v[0-9]*' --sort=-v:refname | head -1)

    local log_range
    [[ -n "$last_tag" ]] && log_range="${last_tag}..HEAD" || log_range="HEAD"

    git -C "$REPO_ROOT" log --no-merges --pretty=format:'%h %s' "$log_range" \
        > "$COMMITS_FILE" 2>/dev/null || true

    PROPOSED_BUMP="patch"
    if grep -qE '(^[a-f0-9]+ )?(feat|fix|refactor|perf|build|chore)(\([^)]+\))?!:' "$COMMITS_FILE" \
       || grep -q 'BREAKING CHANGE' "$COMMITS_FILE"; then
        PROPOSED_BUMP="major"
    elif grep -qE '(^[a-f0-9]+ )?feat(\([^)]+\))?:' "$COMMITS_FILE"; then
        PROPOSED_BUMP="minor"
    fi
}

# ── Changelog generation from commits ─────────────────────────────────

generate_section() {
    local new_version="$1" today="$2" commits_file="$3"

    local tmp_added tmp_fixed tmp_perf tmp_breaking tmp_other
    tmp_added=$(mktemp); tmp_fixed=$(mktemp); tmp_perf=$(mktemp)
    tmp_breaking=$(mktemp); tmp_other=$(mktemp)
    trap 'rm -f "$tmp_added" "$tmp_fixed" "$tmp_perf" "$tmp_breaking" "$tmp_other"' RETURN

    local re_breaking='^(feat|fix|refactor|perf|build|chore)(\([^)]+\))?!'
    local re_feat='^feat(\([^)]+\))?:'
    local re_fix='^fix(\([^)]+\))?:'
    local re_perf='^perf(\([^)]+\))?:'

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local sha="${line%% *}" msg="${line#* }"
        if [[ "$msg" == *"BREAKING CHANGE"* ]] || [[ "$msg" =~ $re_breaking ]]; then
            printf -- '- %s (%s)\n' "$msg" "$sha" >> "$tmp_breaking"
        elif [[ "$msg" =~ $re_feat ]]; then
            printf -- '- %s (%s)\n' "$msg" "$sha" >> "$tmp_added"
        elif [[ "$msg" =~ $re_fix ]]; then
            printf -- '- %s (%s)\n' "$msg" "$sha" >> "$tmp_fixed"
        elif [[ "$msg" =~ $re_perf ]]; then
            printf -- '- %s (%s)\n' "$msg" "$sha" >> "$tmp_perf"
        else
            printf -- '- %s (%s)\n' "$msg" "$sha" >> "$tmp_other"
        fi
    done < "$commits_file"

    printf '## [%s] - %s\n\n' "$new_version" "$today"
    [[ -s "$tmp_breaking" ]] && { echo "### BREAKING CHANGES"; cat "$tmp_breaking"; echo; }
    [[ -s "$tmp_added"    ]] && { echo "### Added";         cat "$tmp_added";    echo; }
    [[ -s "$tmp_fixed"    ]] && { echo "### Fixed";         cat "$tmp_fixed";    echo; }
    [[ -s "$tmp_perf"     ]] && { echo "### Performance";   cat "$tmp_perf";     echo; }
    [[ -s "$tmp_other"    ]] && { echo "### Changed";       cat "$tmp_other";    echo; }
}

# ── Changelog update ──────────────────────────────────────────────────

update_changelog() {
    local new_version="$1" today="$2" changelog="$3"

    if $FROM_COMMITS && [[ -s "${COMMITS_FILE:-}" ]]; then
        local section_file unreleased_file new_cl
        section_file=$(mktemp); unreleased_file=$(mktemp); new_cl=$(mktemp)
        trap 'rm -f "$COMMITS_FILE" "$section_file" "$unreleased_file" "$new_cl"' EXIT

        generate_section "$new_version" "$today" "$COMMITS_FILE" > "$section_file"

        awk '/^## \[Unreleased\]/{flag=1; next} /^## \[/{flag=0} flag' "$changelog" \
            | grep -E '^(### |- )' > "$unreleased_file" || true

        awk -v section_f="$section_file" -v manual_f="$unreleased_file" '
            BEGIN { state = "pre" }
            state == "pre" && /^## \[Unreleased\]/ {
                print "## [Unreleased]"
                print ""
                while ((getline line < section_f) > 0) print line
                close(section_f)
                if ((getline _ < manual_f) > 0) {
                    close(manual_f)
                    print "### Notes (from [Unreleased])"
                    while ((getline line < manual_f) > 0) print line
                    close(manual_f)
                    print ""
                }
                state = "inside"; next
            }
            state == "inside" && /^## \[/ { state = "post" }
            state == "pre" || state == "post" { print }
        ' "$changelog" > "$new_cl"

        mv "$new_cl" "$changelog"
        ok "Updated CHANGELOG.md (generated from commits)"
    else
        sed -i "s/^## \[Unreleased\]/## [Unreleased]\n\n## [$new_version] - $today/" "$changelog"
        ok "Updated CHANGELOG.md (rotated [Unreleased] to [$new_version])"
    fi
}

# ── Usage ─────────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
Usage: release [<command>] [options]

Commands:
  init [<version>]      Initialize VERSION + CHANGELOG.md (default: 0.1.0)
  <major|minor|patch>   Bump version level
  <semver>              Set explicit version (e.g. 1.2.3)

Options:
  --dry-run       Preview without committing
  --push          Push commit and tag to origin
  --from-commits  Auto-propose bump from conventional commits
  --yes           Skip confirmations (CI-friendly)
  --suggest       Print analysis and exit (no side effects)
  --help, -h      Show this help

Examples:
  release init              Set up release tracking
  release patch             Interactive patch bump
  release minor --push      Bump minor, push commit + tag
  release --from-commits    Auto-detect bump from commits
  release --suggest         Show what the next bump would be

Without arguments, release enters interactive mode. If no VERSION file
exists, it offers to initialize.
EOF
}

# ── Main ──────────────────────────────────────────────────────────────

main() {
    ACTION=""
    DRY_RUN=false; PUSH=false; FROM_COMMITS=false; YES=false; SUGGEST_ONLY=false
    COMMITS_FILE=""; PROPOSED_BUMP=""
    INIT_VERSION=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            init)
                ACTION="init"
                if [[ -n "${2:-}" && "$2" != -* ]]; then
                    INIT_VERSION="$2"
                    shift
                fi
                ;;
            --dry-run)       DRY_RUN=true ;;
            --push)          PUSH=true ;;
            --from-commits)  FROM_COMMITS=true ;;
            --yes)           YES=true ;;
            --suggest)       SUGGEST_ONLY=true ;;
            --help|-h)       usage; exit 0 ;;
            --*)             fail "Unknown option: $1" ;;
            *)
                [[ -z "$ACTION" ]] && ACTION="$1" || fail "Unexpected argument: $1"
                ;;
        esac
        shift
    done

    REPO_ROOT="$(find_repo_root "$PWD")" || fail "Not in a git repository. Run from within a git worktree."
    VERSION_FILE="$REPO_ROOT/VERSION"
    CHANGELOG_FILE="$REPO_ROOT/CHANGELOG.md"

    # ── Init ──────────────────────────────────────────────────────────
    if [[ "$ACTION" == "init" ]]; then
        cmd_init "${INIT_VERSION:-0.1.0}"
        exit 0
    fi

    # ── Ensure VERSION exists (prompt to init if missing) ─────────────
    if [[ ! -f "$VERSION_FILE" ]]; then
        log "No VERSION file in $(basename "$REPO_ROOT")."
        read -rp "Initialize release tracking? [Y/n]: " ans
        [[ "${ans:-Y}" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
        cmd_init "0.1.0"
    fi

    CURRENT_VERSION="$(tr -d '[:space:]' < "$VERSION_FILE")"
    BUMP="$ACTION"

    # ── Suggest mode ──────────────────────────────────────────────────
    if $SUGGEST_ONLY; then
        collect_commits
        new_ver="$(bump_version "$CURRENT_VERSION" "$PROPOSED_BUMP")"
        feat_count=$(grep -cE '(^[a-f0-9]+ )?feat(\([^)]+\))?:' "$COMMITS_FILE" 2>/dev/null || true)
        fix_count=$(grep -cE '(^[a-f0-9]+ )?fix(\([^)]+\))?:' "$COMMITS_FILE" 2>/dev/null || true)
        break_count=$(grep -cE '(!:|BREAKING CHANGE)' "$COMMITS_FILE" 2>/dev/null || true)
        total=$(wc -l < "$COMMITS_FILE" 2>/dev/null || echo 0)
        cat <<EOF
repo: $(basename "$REPO_ROOT")
current: $CURRENT_VERSION
proposed_bump: $PROPOSED_BUMP
proposed_version: $new_ver
commits_since_last_tag: $total
  breaking: $break_count
  feat: $feat_count
  fix: $fix_count
EOF
        exit 0
    fi

    # ── Determine bump ────────────────────────────────────────────────
    if [[ -z "$BUMP" ]]; then
        if $FROM_COMMITS; then
            collect_commits
            echo ""
            echo "Repo:    $(basename "$REPO_ROOT")"
            echo "Current: $CURRENT_VERSION"
            echo ""
            if [[ ! -s "$COMMITS_FILE" ]]; then
                warn "No commits since last v* tag."
                echo ""
            else
                echo "Commits since last v* tag:"
                head -30 "$COMMITS_FILE" | sed 's/^/  /'
                count=$(wc -l < "$COMMITS_FILE")
                (( count > 30 )) && echo "  ... ($((count - 30)) more)"
                echo ""
            fi
            echo "Proposed: $PROPOSED_BUMP (→ $(bump_version "$CURRENT_VERSION" "$PROPOSED_BUMP"))"
            echo ""
            if $YES; then
                BUMP="$PROPOSED_BUMP"
            else
                read -rp "Accept [$PROPOSED_BUMP]? (or major/minor/patch/semver): " ans
                BUMP="${ans:-$PROPOSED_BUMP}"
            fi
        else
            echo ""
            echo "Repo:    $(basename "$REPO_ROOT")"
            echo "Current: $CURRENT_VERSION"
            echo ""
            echo "Select bump type:"
            echo "  1) major ($CURRENT_VERSION → $(bump_version "$CURRENT_VERSION" major))"
            echo "  2) minor ($CURRENT_VERSION → $(bump_version "$CURRENT_VERSION" minor))"
            echo "  3) patch ($CURRENT_VERSION → $(bump_version "$CURRENT_VERSION" patch))"
            echo "  4) explicit version"
            echo ""
            read -rp "Choice [3]: " ans
            case "${ans:-3}" in
                1) BUMP="major" ;;
                2) BUMP="minor" ;;
                3) BUMP="patch" ;;
                4) read -rp "Enter version: " BUMP ;;
                *) fail "Invalid choice" ;;
            esac
        fi
    fi

    # If FROM_COMMITS set but BUMP was explicit, still collect for changelog
    if $FROM_COMMITS && [[ ! -s "${COMMITS_FILE:-}" ]]; then
        collect_commits
    fi

    NEW_VERSION="$(bump_version "$CURRENT_VERSION" "$BUMP")"
    [[ -n "$NEW_VERSION" ]] || fail "Invalid bump: $BUMP (use major, minor, patch, or semver)"
    TAG="v${NEW_VERSION}"

    # ── Dry run ───────────────────────────────────────────────────────
    if $DRY_RUN; then
        echo ""
        echo "=== DRY RUN ==="
        echo "Repo:    $(basename "$REPO_ROOT")"
        echo "Version: $CURRENT_VERSION → $NEW_VERSION"
        echo "Tag:     $TAG"
        echo "Files:"
        echo "  $VERSION_FILE"
        echo "  $CHANGELOG_FILE"
        $FROM_COMMITS && echo "  (changelog from commits)" || echo "  (changelog rotation)"
        exit 0
    fi

    # ── Confirm ───────────────────────────────────────────────────────
    echo ""
    echo "Preparing release for $(basename "$REPO_ROOT")"
    echo "  Version: $CURRENT_VERSION → $NEW_VERSION"
    echo "  Tag:     $TAG"
    echo ""
    if ! $YES; then
        read -rp "Proceed? [Y/n]: " ans
        [[ "${ans:-Y}" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
    fi

    # ── Apply ─────────────────────────────────────────────────────────
    echo "$NEW_VERSION" > "$VERSION_FILE"
    ok "Updated VERSION: $NEW_VERSION"

    TODAY="$(date +%Y-%m-%d)"
    if [[ -f "$CHANGELOG_FILE" ]]; then
        update_changelog "$NEW_VERSION" "$TODAY" "$CHANGELOG_FILE"
    fi

    # ── Stage, commit, tag ────────────────────────────────────────────
    git -C "$REPO_ROOT" add VERSION CHANGELOG.md

    if git -C "$REPO_ROOT" diff --cached --quiet; then
        warn "No changes to commit — version already up to date?"
        exit 0
    fi

    COMMIT_MSG="release: v${NEW_VERSION}"
    git -C "$REPO_ROOT" commit -m "$COMMIT_MSG" || fail "Commit failed"
    ok "Committed: $COMMIT_MSG"

    git -C "$REPO_ROOT" tag "$TAG"
    ok "Tagged: $TAG"

    if $PUSH; then
        git -C "$REPO_ROOT" push origin HEAD
        git -C "$REPO_ROOT" push origin "$TAG"
        ok "Pushed commit and tag to origin"
    else
        echo ""
        echo "To push: git push && git push origin $TAG"
    fi

    echo ""
    ok "Release v$NEW_VERSION complete!"
}

main "$@"
