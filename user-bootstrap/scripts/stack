#!/usr/bin/env bash
set -euo pipefail

# stack — Docker Compose stack manager
#
# Usage:
#   stack              Show stack status
#   stack up           Start the stack
#   stack up --dev     Start dev stack (no auth, no SSL, local images)
#   stack down [-v]    Stop the stack (-v deletes volumes, requires confirmation)
#   stack logs [svc]   View logs (or specific service)
#   stack log [svc]    Alias for logs
#   stack build        Rebuild images
#   stack pull         Pull latest images from registry
#   stack ps           Show running containers
#   stack update       Recreate services whose image has changed
#
# Run from any directory inside the project (walks up to find compose file).
# Per-project hooks: place executables in <project-root>/scripts/stack-hooks/<hook-name>
#
# Supported hooks: pre-up, post-up, pre-down, post-down, pre-teardown, post-teardown,
#                  pre-build, post-build, pre-pull, post-pull, pre-update, stack-update, status, logs

# ---------------------------------------------------------------------------
# Mode flags
# ---------------------------------------------------------------------------

DEV_MODE=false
TUNNEL_MODE=false
DO_BUILD=false
DO_PULL=false
FORCE_RECREATE=false
DRY_RUN=false

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log()  { echo -e "\033[1;34m==>\033[0m $*"; }
ok()   { echo -e "\033[1;32m  ✓\033[0m $*"; }
warn() { echo -e "\033[1;33m  ⚠\033[0m $*"; }
fail() { echo -e "\033[1;31m  ✗\033[0m $*" >&2; }

# ---------------------------------------------------------------------------
# Project resolution — walk up from CWD to find a Docker Compose file.
# Stops at the git root, $HOME, or the filesystem root.
# ---------------------------------------------------------------------------

find_project_dir() {
  local dir
  dir="$(pwd)"

  while true; do
    for f in "docker-compose.yml" "docker-compose.yaml" "compose.yml" "compose.yaml"; do
      if [[ -f "${dir}/${f}" ]]; then
        echo "$dir"
        return 0
      fi
    done

    # Stop conditions: git root, home directory, or filesystem root
    if [[ -d "${dir}/.git" || "$dir" == "$HOME" || "$dir" == "/" ]]; then
      break
    fi

    dir="$(dirname "$dir")"
  done

  return 1
}

PROJECT_DIR="$(find_project_dir 2>/dev/null || true)"

if [[ -z "$PROJECT_DIR" ]]; then
  fail "No Docker Compose file found in the current directory or any parent."
  echo "  (looked for docker-compose.yml, docker-compose.yaml, compose.yml, compose.yaml)"
  echo "  Run from inside a project that has a compose file."
  exit 1
fi

PROJECT_NAME="$(basename "$PROJECT_DIR")"

# ---------------------------------------------------------------------------
# Hook dispatcher
# ---------------------------------------------------------------------------

run_hook() {
  local hook_name="$1"
  shift
  local hook_script="${PROJECT_DIR}/scripts/stack-hooks/${hook_name}"
  if [[ -x "$hook_script" ]]; then
    log "Running hook: ${hook_name}"
    "$hook_script" "$@"
  fi
}

# ---------------------------------------------------------------------------
# Compose file helpers
# ---------------------------------------------------------------------------

# Find the primary compose file in a directory.
find_compose_file() {
  local app_dir="$1"
  for file in "docker-compose.yml" "docker-compose.yaml" "compose.yml" "compose.yaml"; do
    if [[ -f "${app_dir}/${file}" ]]; then
      echo "${app_dir}/${file}"
      return 0
    fi
  done
  return 1
}

# Compose args for normal operations: primary file + dev override + requested profiles.
# Profiles are driven by STACK_PROFILES in the project's .env.
# --profile tunnel is appended when --tunnel is passed.
get_compose_args() {
  local app_dir="$1"
  local base_file
  base_file=$(find_compose_file "$app_dir") || return 1

  local args="-f ${base_file}"
  if [[ "$DEV_MODE" == "true" && -f "${app_dir}/docker-compose.dev.yml" ]]; then
    args="${args} -f ${app_dir}/docker-compose.dev.yml"
  fi

  # Read STACK_PROFILES from project .env (single-line grep — avoids overwriting env vars).
  local stack_profiles=""
  if [[ -f "${app_dir}/.env" ]]; then
    stack_profiles=$(grep -E '^STACK_PROFILES=' "${app_dir}/.env" \
      | tail -1 | cut -d= -f2- | sed 's/#.*//' | xargs 2>/dev/null || true)
  fi

  if [[ -n "$stack_profiles" ]]; then
    IFS=',' read -ra _profiles <<< "$stack_profiles"
    for p in "${_profiles[@]}"; do
      p="${p// /}"
      [[ -n "$p" ]] && args="${args} --profile ${p}"
    done
  fi

  # Auto-enable tunnel profile when .env.tunnel is present with a non-empty TUNNEL_TOKEN.
  if [[ -f "${app_dir}/.env.tunnel" ]]; then
    local tunnel_token
    tunnel_token=$(grep -E '^TUNNEL_TOKEN=' "${app_dir}/.env.tunnel" \
      | tail -1 | cut -d= -f2- | sed 's/#.*//' | xargs 2>/dev/null || true)
    if [[ -n "$tunnel_token" ]]; then
      args="${args} --profile tunnel"
    fi
  fi

  # Explicit --tunnel flag override.
  if [[ "$TUNNEL_MODE" == "true" ]]; then
    args="${args} --profile tunnel"
  fi

  echo "$args"
}

# List every profile defined in the compose file(s). Used on `down` and
# `up --remove-orphans` so all profile-gated services are in scope.
get_all_profiles() {
  local app_dir="$1"
  local base_file
  base_file=$(find_compose_file "$app_dir") || return 1
  local files=("-f" "$base_file")
  if [[ "$DEV_MODE" == "true" && -f "${app_dir}/docker-compose.dev.yml" ]]; then
    files+=("-f" "${app_dir}/docker-compose.dev.yml")
  fi
  docker compose "${files[@]}" config --profiles 2>/dev/null | sort -u
}

# Compose args for `down`: same -f files as get_compose_args, but enables
# ALL profiles so nothing is left behind.
get_compose_down_args() {
  local app_dir="$1"
  local base_file
  base_file=$(find_compose_file "$app_dir") || return 1
  local args="-f ${base_file}"
  if [[ "$DEV_MODE" == "true" && -f "${app_dir}/docker-compose.dev.yml" ]]; then
    args="${args} -f ${app_dir}/docker-compose.dev.yml"
  fi
  local profile
  while IFS= read -r profile; do
    [[ -n "$profile" ]] && args="${args} --profile ${profile}"
  done < <(get_all_profiles "$app_dir")
  echo "$args"
}

# Compose args for `pull` and `update --remove-orphans`: all files + all profiles.
get_compose_images_args()       { get_compose_down_args "$@"; }
get_compose_orphan_safe_args()  { get_compose_down_args "$@"; }

# Compute services to start for the caller-requested profile set.
get_start_services() {
  local app_dir="$1"
  local start_args
  start_args=$(get_compose_args "$app_dir") || return 1
  docker compose ${start_args} config --services 2>/dev/null | tr '\n' ' '
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

show_status() {
  local compose_args
  compose_args=$(get_compose_args "$PROJECT_DIR") || {
    warn "No compose file found in ${PROJECT_DIR}"
    return 1
  }

  log "Stack status for ${PROJECT_NAME}:"
  echo ""
  docker compose ${compose_args} ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}"

  run_hook "status"
}

stack_up() {
  local compose_args orphan_args start_services

  compose_args=$(get_compose_args "$PROJECT_DIR") || {
    fail "No compose file found in ${PROJECT_DIR}"
    return 1
  }
  orphan_args=$(get_compose_orphan_safe_args "$PROJECT_DIR") || {
    fail "Failed to enumerate compose profiles in ${PROJECT_DIR}"
    return 1
  }
  start_services=$(get_start_services "$PROJECT_DIR") || {
    fail "Failed to enumerate compose services in ${PROJECT_DIR}"
    return 1
  }

  if [[ "$DEV_MODE" == "true" ]]; then
    log "Starting DEV stack for ${PROJECT_NAME} (no auth, no SSL)..."
  else
    log "Starting stack for ${PROJECT_NAME}..."
  fi

  run_hook "pre-up"

  # Use orphan_args (every profile enabled) for --remove-orphans so
  # profile-gated services (e.g. cloudflared/tunnel) are not reaped.
  # Limit what starts to start_services (caller-requested profiles only).
  if docker compose ${orphan_args} up -d --remove-orphans ${start_services}; then
    ok "Stack started"
  else
    fail "Failed to start stack"
    return 1
  fi

  log "Waiting for services to be healthy..."
  local retries=30 healthy=false
  while [[ $retries -gt 0 ]]; do
    if docker compose ${compose_args} ps | grep -q "(healthy)\|Up"; then
      healthy=true
      break
    fi
    sleep 2
    ((retries--))
  done

  if $healthy; then
    ok "Services are healthy"
    run_hook "post-up"
  else
    warn "Some services may not be healthy yet (check: stack logs)"
    run_hook "post-up"
  fi
}

stack_down() {
  local delete_volumes="${1:-false}"
  local compose_args

  compose_args=$(get_compose_down_args "$PROJECT_DIR") || {
    warn "No compose file found in ${PROJECT_DIR}"
    return 0
  }

  if [[ "$delete_volumes" == "true" ]]; then
    echo ""
    warn "This will DELETE all Docker volumes for ${PROJECT_NAME}."
    warn "All database data, uploaded files, and persistent state will be lost."
    echo ""
    read -rp "Type '${PROJECT_NAME}' to confirm: " confirmation
    if [[ "$confirmation" != "${PROJECT_NAME}" ]]; then
      fail "Confirmation failed. Volumes will not be deleted."
      return 1
    fi
    log "Stopping stack for ${PROJECT_NAME} and deleting volumes..."
    run_hook "pre-teardown"
    if docker compose ${compose_args} down -v --remove-orphans; then
      ok "Stack stopped and volumes deleted"
      run_hook "post-teardown"
    else
      fail "Failed to stop stack"
      return 1
    fi
  else
    log "Stopping stack for ${PROJECT_NAME}..."
    run_hook "pre-down"
    if docker compose ${compose_args} down --remove-orphans; then
      ok "Stack stopped"
      run_hook "post-down"
    else
      fail "Failed to stop stack"
      return 1
    fi
  fi

  # Belt-and-braces: force-remove any lingering containers for this compose project.
  local leftover
  leftover=$(docker ps -aq --filter "label=com.docker.compose.project=${PROJECT_NAME}" 2>/dev/null || true)
  if [[ -n "$leftover" ]]; then
    warn "Force-removing leftover container(s) for ${PROJECT_NAME}"
    echo "$leftover" | xargs -r docker rm -f >/dev/null 2>&1 || true
  fi
}

stack_logs() {
  local service="${1:-}"
  local compose_args

  compose_args=$(get_compose_args "$PROJECT_DIR") || {
    fail "No compose file found in ${PROJECT_DIR}"
    return 1
  }

  local hook_pid=""
  local hook_script="${PROJECT_DIR}/scripts/stack-hooks/logs"
  if [[ -x "$hook_script" ]]; then
    log "Running background hook: logs"
    "$hook_script" "$service" &
    hook_pid=$!
    trap '[[ -n "$hook_pid" ]] && kill "$hook_pid" 2>/dev/null || true' EXIT
  fi

  if [[ -n "$service" ]]; then
    docker compose ${compose_args} logs -f "$service"
  else
    docker compose ${compose_args} logs -f
  fi
}

stack_build() {
  local compose_args

  compose_args=$(get_compose_args "$PROJECT_DIR") || {
    fail "No compose file found in ${PROJECT_DIR}"
    return 1
  }

  log "Building stack images for ${PROJECT_NAME}..."
  run_hook "pre-build"

  if docker compose ${compose_args} build; then
    ok "Images built"
    run_hook "post-build"
  else
    fail "Failed to build images"
    return 1
  fi
}

stack_pull() {
  local compose_args
  compose_args=$(get_compose_images_args "$PROJECT_DIR") || {
    fail "No compose file found in ${PROJECT_DIR}"
    return 1
  }

  log "Pulling latest images for ${PROJECT_NAME}..."

  local images
  images=$(docker compose ${compose_args} config --images 2>/dev/null | sort -u || true)

  if [[ -z "$images" ]]; then
    warn "No images found to pull"
    return 0
  fi

  run_hook "pre-pull"

  local pulled_any=false
  for img in $images; do
    # Pull only registry images (contain '/'); skip local-only images.
    if [[ "$img" == *"/"* ]]; then
      log "Pulling $img..."
      if docker pull "$img"; then
        ok "Pulled $img"
        pulled_any=true
      else
        fail "Failed to pull $img"
        return 1
      fi
    fi
  done

  if $pulled_any; then
    ok "Images pulled"
  else
    ok "No registry images to pull (local-only images skipped)"
  fi
  run_hook "post-pull"
}

# Recreate services whose on-disk image differs from their running container.
# Chainable with --build (runs `build` command first) or --pull (pulls first).
# --force recreates all services. --dry-run previews without applying changes.
stack_update() {
  local compose_args orphan_args start_services
  compose_args=$(get_compose_args "$PROJECT_DIR") || {
    fail "No compose file found in ${PROJECT_DIR}"
    return 1
  }
  orphan_args=$(get_compose_orphan_safe_args "$PROJECT_DIR") || {
    fail "Failed to enumerate compose profiles in ${PROJECT_DIR}"
    return 1
  }
  start_services=$(get_start_services "$PROJECT_DIR") || {
    fail "Failed to enumerate compose services in ${PROJECT_DIR}"
    return 1
  }

  # Optional: build first (looks for `build` on PATH, then <repo>/scripts/build)
  if [[ "$DO_BUILD" == "true" ]]; then
    local build_cmd=""
    if command -v build &>/dev/null; then
      build_cmd="build"
    elif [[ -x "${PROJECT_DIR}/scripts/build" ]]; then
      build_cmd="${PROJECT_DIR}/scripts/build"
    else
      fail "--build: no 'build' command found on PATH and no scripts/build in project"
      return 1
    fi
    log "Building ${PROJECT_NAME} before update..."
    run_hook "pre-build"
    if ! "$build_cmd"; then
      fail "Build failed; aborting update"
      return 1
    fi
    run_hook "post-build"
  fi

  # Optional: pull first
  if [[ "$DO_PULL" == "true" ]]; then
    log "Pulling images before update..."
    run_hook "pre-pull"
    if ! stack_pull; then
      fail "Pull failed; aborting update"
      return 1
    fi
    run_hook "post-pull"
  fi

  run_hook "pre-update"

  # Build pre-flight summary
  log "Stack update state for ${PROJECT_NAME}:"
  echo ""
  printf "%-14s %-14s %-14s %-26s %s\n" "SERVICE" "RUNNING" "AVAILABLE" "VERSION" "STATUS"
  printf "%-14s %-14s %-14s %-26s %s\n" "--------" "--------" "---------" "-------" "------"

  local stale_count=0
  local services_json
  services_json=$(docker compose ${compose_args} config --format json 2>/dev/null || echo "{}")

  local services
  services=$(echo "$services_json" | jq -r '.services | keys[]' 2>/dev/null)

  local svc
  while IFS= read -r svc; do
    [[ -z "$svc" ]] && continue

    local image running_cid running_id available_id version_label build_label version_display status
    image=$(echo "$services_json" | jq -r --arg s "$svc" '.services[$s].image // empty' 2>/dev/null)

    running_cid=$(docker compose ${compose_args} ps -q "$svc" 2>/dev/null | head -1)
    if [[ -n "$running_cid" ]]; then
      running_id=$(docker inspect --format '{{.Image}}' "$running_cid" 2>/dev/null | sed 's|^sha256:||' | cut -c1-12)
    else
      running_id="-"
    fi

    if [[ -n "$image" ]]; then
      available_id=$(docker image inspect "$image" --format '{{.Id}}' 2>/dev/null | sed 's|^sha256:||' | cut -c1-12)
      version_label=$(docker image inspect "$image" --format '{{index .Config.Labels "org.opencontainers.image.version"}}' 2>/dev/null)
      build_label=$(docker image inspect "$image" --format '{{index .Config.Labels "ee.build.number"}}' 2>/dev/null)
      if [[ -n "$version_label" && -n "$build_label" ]]; then
        version_display="v${version_label} build ${build_label}"
      elif [[ -n "$version_label" ]]; then
        version_display="v${version_label}"
      else
        version_display="-"
      fi
    else
      available_id="-"
      version_display="-"
    fi

    if [[ -z "$running_cid" ]]; then
      status="⏸ not running"
    elif [[ "$running_id" == "$available_id" && "$running_id" != "-" ]]; then
      status="✓ current"
    elif [[ "$available_id" == "-" ]]; then
      status="? unknown (image not on host)"
    else
      status="⚠ stale"
      stale_count=$((stale_count + 1))
    fi

    printf "%-14s %-14s %-14s %-26s %s\n" "$svc" "$running_id" "$available_id" "$version_display" "$status"
  done <<< "$services"

  echo ""

  if $DRY_RUN; then
    log "Dry run — no changes applied"
    return 0
  fi

  if [[ "$FORCE_RECREATE" == "true" ]]; then
    log "Forcing recreate of all services..."
    if ! docker compose ${orphan_args} up -d --force-recreate --remove-orphans ${start_services}; then
      fail "Stack update failed"
      return 1
    fi
  elif (( stale_count == 0 )); then
    ok "All services current. Nothing to do."
    return 0
  else
    log "Recreating stale services..."
    if ! docker compose ${orphan_args} up -d --remove-orphans ${start_services}; then
      fail "Stack update failed"
      return 1
    fi
  fi

  ok "Stack updated"
  echo ""
  log "Post-update state:"
  docker compose ${compose_args} ps --format "table {{.Name}}\t{{.Status}}\t{{.Image}}"

  run_hook "stack-update"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

cmd=""
next_arg=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dev)            DEV_MODE=true;       shift ;;
    --tunnel)         TUNNEL_MODE=true;    shift ;;
    --build)          DO_BUILD=true;       shift ;;
    --pull-first)     DO_PULL=true;        shift ;;
    --force)          FORCE_RECREATE=true; shift ;;
    --dry-run)        DRY_RUN=true;        shift ;;
    --help|-h)
      cat <<'EOF'
Usage: stack [options] <command> [args]

Options:
  --dev          Use docker-compose.dev.yml (no auth, local dev mode)
  --tunnel       Also start the Cloudflare tunnel service (profile: tunnel)

Commands:
  up             Start the Docker Compose stack
  down [-v]      Stop the stack (-v deletes volumes, requires confirmation)
  logs [svc]     View logs (optionally for a specific service)
  build          Rebuild Docker images
  pull           Pull latest images from registry
  update         Recreate services whose image has changed
                 Flags: --build (build first) | --pull-first (pull first)
                        --force (recreate all) | --dry-run (preview only)
  ps             Show running containers
  status         Show stack status (default)

Hooks (place executables in <project-root>/scripts/stack-hooks/):
  pre-up, post-up, pre-down, post-down, pre-teardown, post-teardown,
  pre-build, post-build, pre-pull, post-pull, pre-update, stack-update,
  status, logs

Examples:
  stack up                   # Start production stack
  stack --dev up             # Start dev stack (no auth)
  stack --dev --tunnel up    # Dev stack + Cloudflare tunnel
  stack down                 # Stop the stack
  stack down -v              # Stop and delete volumes
  stack logs                 # Tail all logs
  stack logs db              # Tail logs for a specific service
  stack update               # Recreate stale services
  stack update --build       # Build first, then update
  stack update --dry-run     # Preview without applying
EOF
      exit 0
      ;;
    up|down|logs|log|build|pull|update|ps|status)
      cmd="$1"
      shift
      # Capture optional argument for logs/down
      if [[ ("$cmd" == "logs" || "$cmd" == "log" || "$cmd" == "down") && $# -gt 0 && "$1" != --* ]]; then
        next_arg="$1"
        shift
      fi
      ;;
    --*)
      fail "Unknown option: $1"
      exit 1
      ;;
    *)
      fail "Unknown argument: $1"
      echo "Run 'stack --help' for usage."
      exit 1
      ;;
  esac
done

cmd="${cmd:-status}"

# ---------------------------------------------------------------------------
# Print version banner if VERSION file exists at project root
# ---------------------------------------------------------------------------

if [[ -f "${PROJECT_DIR}/VERSION" ]]; then
  version="$(cat "${PROJECT_DIR}/VERSION")"
  log "${PROJECT_NAME} v${version}"
fi

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "$cmd" in
  up)
    if [[ "$TUNNEL_MODE" == "true" && ! -f "${PROJECT_DIR}/.env.tunnel" ]]; then
      fail "--tunnel requires ${PROJECT_DIR}/.env.tunnel"
      exit 1
    fi
    stack_up
    ;;
  down)
    delete_volumes=false
    if [[ "${next_arg:-}" == "-v" || "${next_arg:-}" == "--volumes" ]]; then
      delete_volumes=true
    fi
    for arg in "$@"; do
      [[ "$arg" == "-v" || "$arg" == "--volumes" ]] && delete_volumes=true
    done
    stack_down "$delete_volumes"
    shift $# || true
    ;;
  logs|log)
    stack_logs "${next_arg:-}"
    ;;
  build)
    stack_build
    ;;
  pull)
    stack_pull
    ;;
  update)
    if [[ "$DO_BUILD" == "true" && "$DO_PULL" == "true" ]]; then
      fail "--build and --pull-first are mutually exclusive"
      exit 1
    fi
    stack_update
    ;;
  ps|status)
    show_status
    ;;
  *)
    fail "Unknown command: $cmd"
    echo "Run 'stack --help' for usage."
    exit 1
    ;;
esac
